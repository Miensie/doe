{
  "name": "doe-ai-addin",
  "version": "1.0.0",
  "description": "Add-in Excel — Plans d'expériences (DOE) et optimisation par IA",
  "scripts": {
    "start":     "office-addin-dev-certs install --machine && webpack serve --mode development",
    "build":     "cross-env NODE_ENV=production REPO_NAME=doe webpack --mode production",
    "build:dev": "webpack --mode development",
    "validate":  "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.0",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.7.6",
    "office-addin-dev-certs": "^1.2.0",
    "office-addin-manifest": "^1.9.0",
    "style-loader": "^3.3.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
