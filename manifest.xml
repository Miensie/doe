<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">
  <Id>c3d4e5f6-a7b8-9012-cdef-123456789012</Id>
  <Version>1.0.0</Version>
  <ProviderName>DOE Lab</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="DOE·AI" />
  <Description DefaultValue="Plans d'expériences et optimisation par IA — Minitab-like dans Excel" />
  <IconUrl DefaultValue="https://miensie.github.io/doeicon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://miensie.github.io/doe/icon-64.png" />
  <SupportUrl DefaultValue="https://github.com/miensie/doe" />
  <AppDomains>
    <AppDomain>https://miensie.github.io</AppDomain>
    <AppDomain>https://generativelanguage.googleapis.com</AppDomain>
  </AppDomains>
  <Hosts><Host Name="Workbook" /></Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://miensie.github.io/doe/taskpane.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="DOEGroup">
                <Label resid="Group.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="DOEButton">
                  <Label resid="Button.Label" />
                  <Supertip>
                    <Title resid="Button.Label" />
                    <Description resid="Button.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>DOETaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://miensie.github.io/doe/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://miensie.github.io/doe/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://miensie.github.io/doe/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://miensie.github.io/doe/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://miensie.github.io/doe/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Group.Label"  DefaultValue="DOE·AI" />
        <bt:String id="Button.Label" DefaultValue="DOE·AI" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Button.Tooltip" DefaultValue="Plans d'expériences et optimisation IA" />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
